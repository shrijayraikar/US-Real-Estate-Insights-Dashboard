    <worksheet name='Distribution of Sale Amounts'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#f20004' fontname='Arial Rounded MT Bold' fontsize='9'>Distribution of Sale Amounts</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Sheet1 (Real_Estate_Sales_2011-2022_GL_1 (1))' name='federated.1ozkl290hy6zqo18yhtzn1tejrjz' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='Metric Selector' datatype='string' name='[Parameter 1]' param-domain-type='list' role='measure' type='nominal' value='&quot;Sale Amount&quot;'>
              <calculation class='tableau' formula='&quot;Sale Amount&quot;' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.1ozkl290hy6zqo18yhtzn1tejrjz'>
            <column datatype='integer' name='[Assessed Value]' role='measure' type='quantitative' />
            <column caption='Residential Type Cal' datatype='string' name='[Calculation_0336464080044033]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IFNULL([Residential Type], &quot;Non-Residential&quot;)' />
            </column>
            <column caption='Sale Category' datatype='string' name='[Calculation_0644326018850816]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Sale Amount]&gt;= 326000 THEN &quot;High&quot;&#13;&#10;ELSEIF [Sale Amount]&gt;= 175000 THEN &quot;Medium&quot; &#13;&#10;ELSE &quot;Low&quot;&#13;&#10;END' />
            </column>
            <column caption='Sale Year' datatype='date' datatype-customized='true' name='[Calculation_1059391342854144]' role='dimension' type='quantitative'>
              <calculation class='tableau' formula='DATE(DATEPARSE ( &quot;yyyy&quot;, STR(Year([Date Recorded])) )) ' />
            </column>
            <column caption='Selected Metric' datatype='real' name='[Calculation_1483253745487872]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CASE [Parameters].[Parameter 1] WHEN &quot;Sale Amount&quot; THEN [Sale Amount] WHEN &quot;Assessed Value&quot; THEN [Assessed Value] END' />
            </column>
            <column datatype='date' name='[Date Recorded]' role='dimension' type='ordinal' />
            <column datatype='string' name='[Residential Type]' role='dimension' type='nominal' />
            <column aggregation='None' datatype='integer' name='[Sale Amount (bin)]' role='dimension' type='quantitative'>
              <calculation class='bin' decimals='4' formula='[Sale Amount]' peg='0' size='50000' />
            </column>
            <column datatype='real' name='[Sale Amount]' role='measure' type='quantitative' />
            <column datatype='string' name='[State]' role='dimension' semantic-role='[State].[Name]' type='nominal' />
            <column datatype='string' name='[Town]' role='dimension' semantic-role='[State].[Name]' type='nominal' />
            <column-instance column='[Calculation_1483253745487872]' derivation='Count' name='[cnt:Calculation_1483253745487872:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Sale Amount]' derivation='Count' name='[cnt:Sale Amount:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Sale Amount]' derivation='Max' name='[max:Sale Amount:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_0336464080044033]' derivation='None' name='[none:Calculation_0336464080044033:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_0644326018850816]' derivation='None' name='[none:Calculation_0644326018850816:nk]' pivot='key' type='nominal' />
            <column-instance column='[Sale Amount (bin)]' derivation='None' name='[none:Sale Amount (bin):qk]' pivot='key' type='quantitative' />
            <column-instance column='[State]' derivation='None' name='[none:State:nk]' pivot='key' type='nominal' />
            <column-instance column='[Sale Amount]' derivation='Sum' name='[sum:Sale Amount:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_1059391342854144]' derivation='Year' name='[yr:Calculation_1059391342854144:ok]' pivot='key' type='ordinal' />
          </datasource-dependencies>
          <filter class='quantitative' column='[federated.1ozkl290hy6zqo18yhtzn1tejrjz].[max:Sale Amount:qk]' included-values='in-range'>
            <min>2000.0</min>
            <max>2600000.0</max>
          </filter>
